{
  "info": {
    "name": "kanzamall-all-api",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Complete KanzaMall API collection for local development. Set environment variable baseUrl (default http://localhost:3000) and authToken."
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/api/health", "host": ["{{baseUrl}}"], "path": ["api","health"] }
      }
    },
    {
      "name": "Auth - Admin Login",
      "request": {
        "method": "POST",
        "body": { "mode": "raw", "raw": "{\"username\":\"admin\",\"password\":\"admin123\"}", "options": { "raw": { "language": "json" } } },
        "url": { "raw": "{{baseUrl}}/api/auth/admin/login", "host": ["{{baseUrl}}"], "path": ["api","auth","admin","login"] }
      }
    },
    {
      "name": "Auth - Customer Register",
      "request": {
        "method": "POST",
        "body": { "mode": "raw", "raw": "{\"firstname\":\"Budi Santoso\",\"email\":\"budi@example.com\",\"telephone\":\"081234567890\",\"password\":\"password123\",\"confirm_password\":\"password123\",\"kode_kanza\":\"KA2400001\",\"agree\":true}", "options": { "raw": { "language": "json" } } },
        "url": { "raw": "{{baseUrl}}/api/auth/customer/register", "host": ["{{baseUrl}}"], "path": ["api","auth","customer","register"] }
      }
    },
    {
      "name": "Auth - Customer Login",
      "request": {
        "method": "POST",
        "body": { "mode": "raw", "raw": "{\"telephone\":\"081234567890\",\"password\":\"password123\"}", "options": { "raw": { "language": "json" } } },
        "url": { "raw": "{{baseUrl}}/api/auth/customer/login", "host": ["{{baseUrl}}"], "path": ["api","auth","customer","login"] }
      }
    },
    {
      "name": "Auth - Get Customer by ID",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
        "url": { "raw": "{{baseUrl}}/api/auth/customer/123", "host": ["{{baseUrl}}"], "path": ["api","auth","customer","123"] }
      }
    },
    {
      "name": "Auth - Update Customer (multipart)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "customer_id", "value": "123", "type": "text" },
            { "key": "firstname", "value": "Budi", "type": "text" },
            { "key": "email", "value": "budi@example.com", "type": "text" },
            { "key": "store_id", "value": "1", "type": "text" },
            { "key": "no_rek", "value": "12345678", "type": "text" },
            { "key": "nama_rek", "value": "Budi", "type": "text" },
            { "key": "nama_bank", "value": "BCA", "type": "text" },
            { "key": "nik", "value": "", "type": "text" },
            { "key": "kk", "value": "", "type": "text" },
            { "key": "image", "type": "file" }
          ]
        },
        "url": { "raw": "{{baseUrl}}/api/auth/customer/update", "host": ["{{baseUrl}}"], "path": ["api","auth","customer","update"] }
      }
    },
